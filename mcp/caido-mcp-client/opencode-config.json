{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "caido": {
      "type": "local",
      "command": ["npx", "-y", "@caido/mcp-server"],
      "enabled": true,
      "environment": {
        "CAIDO_API_KEY": "{env:CAIDO_API_KEY}",
        "CAIDO_URL": "{env:CAIDO_URL}"
      }
    }
  }
}
